{
  "name": "@rapidkey/frontend",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "eslint": "eslint \"./**/*.ts\"",
    "oxlint": "oxlint .",
    "lint": "npm run oxlint && npm run eslint",
    "check-assets": "tsx ./scripts/check-assets.ts",
    "audit": "vite-bundle-visualizer",
    "dep-graph": "madge -c -i \"dep-graph.png\" ./src/ts",
    "ts-check": "tsc --noEmit",
    "build": "npm run build:local",
    "build:local": "npm run madge && vite build",
    "build:rapidkey": "npm run madge && cross-env BASE_PATH=/RapidKey/ vite build",
    "madge": " madge --circular --extensions ts ./src",
    "start": "vite preview --port 3000",
    "dev": "vite dev",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage",
    "dev-test": "concurrently --kill-others \"vite dev\" \"vitest\"",
    "tsc": "tsc"
  },
  "engines": {
    "node": "20.18.0"
  },
  "browserslist": [
    "defaults",
    "not op_mini all",
    "not dead"
  ],
  "devDependencies": {
    "@fortawesome/fontawesome-free": "5.15.4",
    "@rapidkey/eslint-config": "workspace:*",
    "@rapidkey/oxlint-config": "workspace:*",
    "@rapidkey/schemas": "workspace:*",
    "@rapidkey/typescript-config": "workspace:*",
    "@types/canvas-confetti": "1.4.3",
    "@types/chartjs-plugin-trendline": "1.0.1",
    "@types/damerau-levenshtein": "1.0.0",
    "@types/howler": "2.2.7",
    "@types/jquery": "3.5.14",
    "@types/node": "20.14.11",
    "@types/object-hash": "3.0.6",
    "@types/qrcode": "1.5.5",
    "@types/subset-font": "1.4.3",
    "@types/throttle-debounce": "5.0.2",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "10.4.20",
    "concurrently": "8.2.2",
    "dotenv": "16.4.5",
    "eslint": "8.57.1",
    "eslint-plugin-compat": "6.0.2",
    "fontawesome-subset": "4.4.0",
    "happy-dom": "20.8.9",
    "madge": "8.0.0",
    "magic-string": "0.30.17",
    "normalize.css": "8.0.1",
    "oxlint": "1.15.0",
    "postcss": "8.4.31",
    "sass": "1.70.0",
    "subset-font": "2.3.0",
    "tsx": "4.16.2",
    "typescript": "5.5.4",
    "unplugin-inject-preload": "3.0.0",
    "vite": "6.4.2",
    "vite-bundle-visualizer": "1.0.1",
    "vite-plugin-checker": "0.7.2",
    "vite-plugin-html-inject": "1.1.2",
    "vite-plugin-inspect": "11.0.0",
    "vite-plugin-minify": "2.1.0",
    "vite-plugin-oxlint": "1.3.1",
    "vite-plugin-pwa": "1.0.0",
    "cross-env": "7.0.3",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@date-fns/utc": "1.2.0",
    "@rapidkey/util": "workspace:*",
    "balloon-css": "1.2.0",
    "canvas-confetti": "1.5.1",
    "chart.js": "3.7.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "chartjs-plugin-annotation": "2.2.1",
    "chartjs-plugin-trendline": "1.0.2",
    "color-blend": "4.0.0",
    "damerau-levenshtein": "1.0.8",
    "date-fns": "3.6.0",
    "hangul-js": "0.2.6",
    "howler": "2.2.3",
    "idb": "8.0.3",
    "jquery": "3.7.1",
    "jquery-color": "2.2.0",
    "jquery.easing": "1.4.1",
    "konami": "1.7.0",
    "lz-ts": "1.1.2",
    "modern-screenshot": "4.6.5",
    "object-hash": "3.0.0",
    "qrcode": "1.5.4",
    "slim-select": "2.9.2",
    "stemmer": "2.0.1",
    "throttle-debounce": "5.0.2",
    "zod": "3.23.8",
    "zod-urlsearchparams": "0.0.16"
  }
}