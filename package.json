{
  "name": "rapidkey",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "full-check": "turbo lint ts-check build test check-assets --force",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "ts-check": "turbo run ts-check",
    "lint": "turbo run lint",
    "lint-fe": "turbo run lint --filter @rapidkey/frontend",
    "lint-pkg": "turbo run lint --filter=\"./packages/*\"",
    "oxlint": "turbo run oxlint",
    "oxlint-fe": "turbo run oxlint --filter @rapidkey/frontend",
    "oxlint-pkg": "turbo run oxlint --filter=\"./packages/*\"",
    "build": "turbo run build",
    "build-fe": "turbo run build --filter @rapidkey/frontend",
    "build-pkg": "turbo run build --filter=\"./packages/*\"",
    "test": "turbo run test",
    "test-fe": "turbo run test --filter @rapidkey/frontend",
    "test-pkg": "turbo run test --filter=\"./packages/*\"",
    "dev": "turbo run dev --force",
    "dev-fe": "turbo run dev --force --filter @rapidkey/frontend",
    "dev-pkg": "turbo run dev --force --filter=\"./packages/*\"",
    "start": "turbo run start",
    "start-fe": "turbo run start --filter @rapidkey/frontend",
    "audit-fe": "cd frontend && npm run audit",
    "release": "rapidkey-release",
    "release-fe": "rapidkey-release --fe",
    "release-no-deploy": "rapidkey-release --no-deploy",
    "release-dry": "rapidkey-release --dry",
    "hotfix": "rapidkey-release --hotfix",
    "hotfix-fe": "rapidkey-release --hotfix --fe",
    "hotfix-dry": "rapidkey-release --hotfix --dry",
    "pretty-check": "prettier --check .",
    "pretty-check-fe": "prettier --check ./frontend/src",
    "pretty-check-assets": "prettier --check ./frontend/static",
    "pretty-check-pkg": "prettier --check ./packages",
    "pretty-fix": "prettier --write .",
    "pretty-fix-fe": "prettier --write ./frontend/src",
    "pretty-fix-assets": "prettier --write ./frontend/static",
    "pretty-fix-pkg": "prettier --write ./packages",
    "lint-json-assets": "cd frontend && eslint \"./static/**/*.json\"",
    "check-assets": "turbo check-assets --filter @rapidkey/frontend",
    "check-assets-quotes": "turbo check-assets --filter @rapidkey/frontend  -- quotes",
    "check-assets-languages": "turbo check-assets --filter @rapidkey/frontend  -- languages",
    "check-assets-others": "turbo check-assets --filter @rapidkey/frontend  -- others"
  },
  "engines": {
    "node": "20.18.0"
  },
  "devDependencies": {
    "@commitlint/cli": "17.7.1",
    "@commitlint/config-conventional": "19.2.2",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "8.57.1",
    "husky": "8.0.1",
    "knip": "2.19.2",
    "lint-staged": "13.2.3",
    "only-allow": "1.2.1",
    "oxlint": "1.15.0",
    "prettier": "2.8.8",
    "turbo": "2.5.6",
    "vitest": "3.2.4"
  },
  "lint-staged": {
    "*.{json,scss,css,html}": [
      "prettier --write"
    ],
    "*.{ts,js}": [
      "prettier --write",
      "oxlint",
      "eslint"
    ]
  },
  "version": "25.36.0",
  "packageManager": "pnpm@9.6.0"
}
